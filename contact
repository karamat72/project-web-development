<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: linear-gradient(135deg, #0a0a0a, #1c1c1c);
    color: white;
}

.wrapper {
    max-width: 1100px;
    margin: 60px auto;
    display: flex;
    gap: 25px;
    padding: 20px;
}

.card {
    flex: 1;
    background: rgba(0,0,0,0.75);
    border: 2px solid #00bcd4;
    border-radius: 15px;
    padding: 25px;
    box-shadow: 0 0 15px rgba(0,188,212,0.2);
}

h1 {
    color: #00bcd4;
    text-align: center;
    margin-bottom: 20px;
}

p {
    line-height: 1.8;
    font-size: 16px;
}

.highlight {
    color: #00bcd4;
    font-weight: bold;
}

/* IMAGE */
.image-box {
    width: 200px;
}

.image-box img {
    width: 100%;
    height: auto;
    border-radius: 15px;
    border: 2px solid #00bcd4;
    object-fit: cover;
}

button {
    display: block;
    margin: 20px auto 0;
    padding: 10px 25px;
    background: #00bcd4;
    border: none;
    color: white;
    border-radius: 5px;
    cursor: pointer;
    transition: 0.3s;
}

button:hover {
    background: #0097a7;
}

@media (max-width: 900px) {
    .wrapper {
        flex-direction: column;
        align-items: center;
    }

    .image-box {
        width: 100%;
    }
}
</style>
</head>

