<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Car Booking</title>

<style>
body {
    font-family: Arial;
    color: white;
    text-align: center;
    background-size: cover;
    background-position: center;
    transition: 1s;
}

.container {
    width: 90%;
    max-width: 400px;
    margin: 60px auto;
    background: rgba(0,0,0,0.7);
    padding: 20px;
    border-radius: 10px;
    border: 2px solid #00bcd4;
}

h2 {
    margin-bottom: 20px;
    color: #00bcd4;
}

input, select {
    width: 90%;
    padding: 10px;
    margin: 8px;
    border-radius: 5px;
    border: none;
}

button {
    padding: 10px 20px;
    background: #00bcd4;
    border: none;
    color: white;
    cursor: pointer;
    border-radius: 5px;
}

button:hover {
    background: #0097a7;
}
</style>
</head>

<body>

<div class="container">

    <h2>Car Booking Form</h2>

    <input type="text" id="name" placeholder="Full Name">
    <input type="number" id="phone" placeholder="Phone Number">
    <input type="text" id="cnic" placeholder="CNIC Number">
    <input type="text" id="address" placeholder="Address">

    <select id="car">
        <option>Corolla</option>
        <option>Vitz</option>
        <option>TX</option>
        <option>Prado</option>
    </select>

    <input type="text" id="pickup" placeholder="Pickup Location">
    <input type="date" id="date">
    <input type="number" id="days" placeholder="Number of Days">

    <button onclick="submitForm()">Submit Booking</button>

    <h3 id="result"></h3>

</div>

<script>

/* BACKGROUND CAR SLIDER */
const carImages = [
    "https://images.unsplash.com/photo-1552519507-da3b142c6e3d",
    "https://images.unsplash.com/photo-1549924231-f129b911e442",
    "https://images.unsplash.com/photo-1502877338535-766e1452684a",
    "https://images.unsplash.com/photo-1511919884226-fd3cad34687c"
];

let i = 0;

function changeBackground() {
    document.body.style.backgroundImage = "url('" + carImages[i] + "')";
    i = (i + 1) % carImages.length;
}

setInterval(changeBackground, 3000);
changeBackground();


/* SUBMIT FUNCTION */
function submitForm() {
    let name = document.getElementById("name").value;
    let phone = document.getElementById("phone").value;
    let cnic = document.getElementById("cnic").value;
    let address = document.getElementById("address").value;
    let car = document.getElementById("car").value;
    let pickup = document.getElementById("pickup").value;
    let date = document.getElementById("date").value;
    let days = document.getElementById("days").value;

    if(name === "" || phone === "" || cnic === "" || address === "" || pickup === "" || date === "" || days === ""){
        document.getElementById("result").innerText = "Please fill all fields";
        return;
    }

    document.getElementById("result").innerText = "Booking Successful!";
}

</script>

</body>
</html>
